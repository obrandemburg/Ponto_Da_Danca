{
  "openapi": "3.1.1",
  "info": {
    "title": "Ponto_Da_Danca | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7010"
    },
    {
      "url": "http://localhost:5164"
    }
  ],
  "paths": {
    "/api/usuarios": {
      "post": {
        "tags": [
          "Ponto_Da_Danca"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CriarUsuarioRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Autenticação"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          }
        }
      }
    },
    "/api/turmas": {
      "get": {
        "tags": [
          "Ponto_Da_Danca"
        ],
        "parameters": [
          {
            "name": "modalidade",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "nivel",
            "in": "query",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "diaSemana",
            "in": "query",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "post": {
        "tags": [
          "Ponto_Da_Danca"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CriarTurmaRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CriarTurmaRequest": {
        "required": [
          "ritmoId",
          "professorId",
          "horario",
          "diaFixoSemana",
          "sala",
          "limiteAlunos",
          "nivelTecnico",
          "dataInicio"
        ],
        "type": "object",
        "properties": {
          "ritmoId": {
            "type": "string",
            "format": "uuid"
          },
          "professorId": {
            "type": "string",
            "format": "uuid"
          },
          "horario": {
            "type": "string"
          },
          "diaFixoSemana": {
            "type": "string"
          },
          "sala": {
            "type": "string"
          },
          "limiteAlunos": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "nivelTecnico": {
            "type": "string"
          },
          "dataInicio": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CriarUsuarioRequest": {
        "required": [
          "nome",
          "email",
          "senha",
          "tipo"
        ],
        "type": "object",
        "properties": {
          "nome": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "senha": {
            "type": "string"
          },
          "tipo": {
            "type": "string"
          }
        }
      },
      "LoginRequest": {
        "required": [
          "email",
          "senha"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "senha": {
            "type": "string"
          }
        }
      },
      "LoginResponse": {
        "required": [
          "token",
          "nome",
          "tipo"
        ],
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "nome": {
            "type": "string"
          },
          "tipo": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "security": [
    {
      "Bearer": [ ]
    }
  ],
  "tags": [
    {
      "name": "Ponto_Da_Danca"
    },
    {
      "name": "Autenticação"
    }
  ]
}